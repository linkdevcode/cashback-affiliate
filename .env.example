# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=cashback
POSTGRES_PORT=5432

# API (use 5050 on macOS — port 5000 is used by AirPlay Receiver)
API_PORT=5050
JWT_SECRET=CHANGE_ME_USE_ENV_VAR_IN_PRODUCTION_MIN_32_CHARS
JWT_ISSUER=cashback-api
JWT_AUDIENCE=cashback-client
GOOGLE_CLIENT_ID=CHANGE_ME_GOOGLE_CLIENT_ID

# Accesstrade
ACCESSTRADE_BASE_URL=https://api.accesstrade.vn
ACCESSTRADE_TOKEN=CHANGE_ME_ACCESSTRADE_TOKEN
ACCESSTRADE_CAMPAIGN_ID=CHANGE_ME_ACCESSTRADE_CAMPAIGN_ID

# Frontend build (docker build arg)
NEXT_PUBLIC_API_URL=http://localhost:5050/api/v1
